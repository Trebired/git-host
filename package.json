{
  "name": "@trebired/git-host",
  "version": "1.6.0",
  "description": "Embeddable Git forge for Node.js and Bun apps, built on the real Git CLI with HTTP, SSH, browser, and repository platform APIs.",
  "license": "MIT",
  "keywords": [
    "git",
    "git-host",
    "git-forge",
    "hosting",
    "backend",
    "browser",
    "node",
    "bun"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Trebired/git-host"
  },
  "bugs": {
    "url": "https://github.com/Trebired/git-host/issues"
  },
  "homepage": "https://github.com/Trebired/git-host#readme",
  "type": "module",
  "engines": {
    "node": ">=18",
    "bun": ">=1.0.0"
  },
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "bun@1.3.12",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    },
    "./browser": {
      "types": "./dist/browser/index.d.ts",
      "import": "./dist/browser/index.js"
    },
    "./browser/styles.css": "./dist/browser/styles.css"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && mkdir -p dist/browser && cp src/browser/styles.css dist/browser/styles.css",
    "demo": "bun run examples/dummy.ts",
    "demo:api": "bun run examples/api_server.ts",
    "demo:http": "bun run examples/http_server.ts",
    "demo:ssh": "bun run examples/ssh_server.ts",
    "prepublishOnly": "bun run typecheck && bun test && bun run build",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@trebired/logger-adapter": "^0.2.0",
    "linguist-js": "^3.0.0",
    "material-icon-theme": "^5.35.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "ssh2": "^1.17.0"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "^1.3.4",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-test-renderer": "^19.1.0",
    "@types/ssh2": "^1.15.5",
    "react": "^19.2.0",
    "react-test-renderer": "^19.2.0",
    "typescript": "^6.0.2"
  }
}
